{
  "uri": "/*",
  "name": "casdoor",
  "desc": "Proxy Casdoor; match Host casdoor.localhost on port 9080",
  "hosts": ["casdoor.localhost"],
  "methods": [
    "GET",
    "POST",
    "PUT",
    "DELETE",
    "PATCH",
    "OPTIONS"
  ],
  "upstream": {
    "nodes": [
      {
        "host": "casdoor",
        "port": 8000,
        "weight": 1
      }
    ],
    "timeout": {
      "connect": 60,
      "send": 60,
      "read": 60
    },
    "type": "roundrobin",
    "scheme": "http",
    "pass_host": "pass",
    "keepalive_pool": {
      "idle_timeout": 60,
      "requests": 1000,
      "size": 320
    }
  },
  "status": 1
}
