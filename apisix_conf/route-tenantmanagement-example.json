{
  "uri": "/tenant/*",
  "name": "tenant-management",
  "desc": "Proxy TenantManagement service under APISIX",
  "methods": [
    "GET",
    "POST",
    "PUT",
    "DELETE",
    "PATCH",
    "OPTIONS"
  ],
  "upstream": {
    "nodes": [
      {
        "host": "tenantmanagement",
        "port": 8080,
        "weight": 1
      }
    ],
    "timeout": {
      "connect": 6,
      "send": 6,
      "read": 6
    },
    "type": "roundrobin",
    "scheme": "http",
    "pass_host": "pass",
    "keepalive_pool": {
      "idle_timeout": 60,
      "requests": 1000,
      "size": 320
    }
  },
  "plugins": {
    "proxy-rewrite": {
      "regex_uri": [
        "^/tenant/(.*)",
        "/$1"
      ]
    }
  },
  "status": 1
}
